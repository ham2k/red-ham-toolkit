{
  "name": "@ham2k/lib-callsigns",
  "version": "1.0.2",
  "description": "Library for working with amateur radio callsigns",
  "author": "Sebastian Delmont <sd@ham2k.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ham2k/ham-js-libs.git"
  },
  "homepage": "https://github.com/ham2k/ham-js-libs/tree/main/packages/lib-callsigns",
  "license": "MIT",
  "keywords": [
    "amateur radio",
    "ham radio",
    "callsigns"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "jest": "^30.2.0",
    "standard": "^17.0.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "standard": {
    "env": [
      "jest"
    ]
  }
}